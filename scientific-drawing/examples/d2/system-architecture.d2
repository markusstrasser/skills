# Scientific Computing System Architecture
# Demonstrates D2 v0.7 features: icons, markdown labels, legends

direction: right

# Research nodes with rich markdown content
data_collection: Data Collection {
  description: |md
    ## Data Sources
    - Sensors
    - Instruments
    - External APIs
  |
  shape: cylinder
  style.fill: "#e3f2fd"
}

preprocessing: Preprocessing {
  algorithm: |md
    ```python
    def normalize(data):
        return (data - mean) / std
    ```
  |
  shape: rectangle
  style.fill: "#fff3e0"
}

ml_pipeline: ML Pipeline {
  model: |md
    ## Architecture
    - Input: $\mathbb{R}^{n \times d}$
    - Hidden: $h = \sigma(Wx + b)$
    - Output: $\hat{y} = softmax(h)$
  |
  shape: hexagon
  style.fill: "#f3e5f5"
}

results_db: Results Database {
  shape: cylinder
  style.fill: "#e8f5e9"
}

visualization: Visualization {
  shape: page
  style.fill: "#fff9c4"
}

# Connections with labels
data_collection -> preprocessing: Raw data
preprocessing -> ml_pipeline: Normalized features
ml_pipeline -> results_db: Predictions & metrics
results_db -> visualization: Query results

# Legend
legend: {
  data_storage: {
    label: "Data Storage"
    shape: cylinder
    style.fill: "#e3f2fd"
  }
  processing: {
    label: "Processing"
    shape: rectangle
    style.fill: "#fff3e0"
  }
  analytics: {
    label: "Analytics"
    shape: hexagon
    style.fill: "#f3e5f5"
  }
}
