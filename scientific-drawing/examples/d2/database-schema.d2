# Research Database Schema
# Demonstrates SQL table features (v0.7) - best with TALA layout

experiments: {
  shape: sql_table
  id: int {constraint: primary_key}
  name: varchar(255) {constraint: unique}
  created_at: timestamp
  status: enum(pending,running,completed)
  parameters: jsonb
}

datasets: {
  shape: sql_table
  id: int {constraint: primary_key}
  experiment_id: int {constraint: foreign_key}
  name: varchar(255)
  size_mb: decimal
  format: varchar(50)
  created_at: timestamp
}

results: {
  shape: sql_table
  id: int {constraint: primary_key}
  experiment_id: int {constraint: foreign_key}
  metric_name: varchar(100)
  metric_value: float
  recorded_at: timestamp
}

models: {
  shape: sql_table
  id: int {constraint: primary_key}
  experiment_id: int {constraint: foreign_key}
  architecture: varchar(255)
  hyperparameters: jsonb
  training_time_sec: int
  accuracy: float
}

# Relationships
datasets.experiment_id -> experiments.id
results.experiment_id -> experiments.id
models.experiment_id -> experiments.id
