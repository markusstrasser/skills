{:categories
 {:build-failure
  {:signals ["shadow-cljs.*failed"
             "Compilation failed"
             "Build failure"
             "Cannot find module"]
   :remedies ["Check shadow-cljs.edn for typos"
              "Verify all deps in deps.edn"
              "Clear cache: npm run clean"
              "Restart shadow-cljs: npm run dev"]}
  
  :namespace-not-found
  {:signals ["No such namespace"
             "Could not require"
             "cljs.analyzer.*resolve.*not found"
             "Namespace.*does not exist"]
   :remedies ["Check namespace declaration matches file path"
              "Verify deps.edn :paths includes parent directory"
              "Check for circular requires"
              "Restart REPL and reconnect"]}
  
  :test-timeout
  {:signals ["Execution timed out"
             "Test.*timeout"
             "Process.*timed out"]
   :remedies ["Check for infinite loops in test code"
              "Increase timeout in shadow-cljs.edn"
              "Look for blocking I/O or promises"
              "Check test fixtures for resource leaks"]}
  
  :cache-corruption
  {:signals ["ClassCastException"
             "AbstractMethodError"
             "Stale compilation"
             "Inconsistent.*cache"]
   :remedies ["Nuclear option: npm run clean"
              "Clear shadow-cljs cache: rm -rf .shadow-cljs"
              "Clear node modules: rm -rf node_modules && npm install"
              "Check for multiple shadow-cljs versions"]}
  
  :port-conflict
  {:signals ["EADDRINUSE"
             "Address already in use"
             "Port.*already.*bound"]
   :remedies ["Kill process on port 8080: lsof -ti :8080 | xargs kill"
              "Kill process on port 7888: lsof -ti :7888 | xargs kill"
              "Check for zombie shadow-cljs: pkill -f shadow-cljs"]}
  
  :reader-conditional-error
  {:signals ["Reader conditional.*not.*allowed"
             "Conditional read not allowed"
             "#\\?.*not.*allowed"]
   :remedies ["Check file extension: .cljc for cross-platform code"
              "Verify reader conditionals use #? or #?@"
              "Check for bare js/ refs in .cljc files"]}
  
  :macro-expansion-error
  {:signals ["Unable to resolve symbol.*in this context"
             "Macros.*cannot be.*used as functions"
             "Can't take value of a macro"]
   :remedies ["Check if requiring macro namespace with :require-macros"
              "Verify macro is defined before use"
              "Check for circular macro dependencies"
              "Use fully qualified symbols in macro-generated code"]}
  
  :repl-disconnect
  {:signals ["nREPL.*closed"
             "Connection refused.*7888"
             "REPL.*not connected"]
   :remedies ["Restart nREPL: npm run mcp"
              "Check nREPL port in deps.edn matches client"
              "Verify JVM process is running: jps | grep nrepl"
              "Check firewall blocking port 7888"]}
  
  :linting-failure
  {:signals ["clj-kondo.*error"
             "Unresolved symbol"
             "Unused.*namespace"]
   :remedies ["Review clj-kondo output for details"
              "Add namespace to :lint-as config if legitimate"
              "Check for typos in symbol names"
              "Update .clj-kondo/config.edn exclusions"]}}
 
 :patterns
 {:extract-error-type
  {:regex "(?i)(error|exception|failure|timeout|not found)"
   :priority [:signals :remedies]}
  
  :extract-namespace
  {:regex "([a-z][a-z0-9-]*\\.)+[a-z][a-z0-9-]*"
   :context :namespace-not-found}
  
  :extract-port
  {:regex ":\\d{4,5}"
   :context :port-conflict}}} :goog-string-format-missing
 {:pattern "goog.string.format is not a function"
  :description "Missing goog.string.format import in ClojureScript"
  :remedy ["Add to namespace requires: #?(:cljs [goog.string.format])"
           "Common when using gstr/format in CLJS code"]
  :auto-fix "Add import to ns form"
  :confidence :high
  :frequency :common}

 :repl-connection-failed
 {:pattern "Unable to reach the nREPL"
  :description "REPL server unreachable or down"
  :remedy ["Check shadow-cljs server: nc -z localhost 9000"
           "Restart dev server: npm run dev"
           "Check for port conflicts: lsof -i :9000"]
  :auto-fix "dev/scripts/restart-dev-env.sh"
  :confidence :medium
  :frequency :occasional}

 :shadow-cljs-compilation-failed
 {:pattern "Build failed|Compilation failed"
  :description "Shadow-cljs build/compilation errors"
  :remedy ["Check syntax errors in source files"
           "Verify all dependencies are installed: npm install"
           "Clear shadow-cljs cache: npx shadow-cljs clean"]
  :auto-fix "npx shadow-cljs clean && npm install"
  :confidence :medium
  :frequency :common}

 :test-timeout
 {:pattern "Test timeout|Execution timeout"
  :description "Tests taking too long or hanging"
  :remedy ["Check for infinite loops in test code"
           "Increase timeout in test runner"
           "Check REPL responsiveness: npm run agent:health"]
  :confidence :low
  :frequency :rare}

 :llmx-gpt5-temperature-error
 {:pattern "gpt-5 models.*don't support temperature|UnsupportedParamsError.*temperature"
  :description "GPT-5 models only support temperature=1, but default is 0.7"
  :remedy ["Update llmx to latest version (auto-adjusts temperature)"
           "Manually specify --temperature 1 for GPT-5 models"
           "Use llmx without temperature flag (auto-adjusted in v0.1.0+)"]
  :auto-fix "uv tool install --force --editable ~/Projects/llmx"
  :confidence :high
  :frequency :common}

 :llmx-api-quota-error
 {:pattern "exceeded your current quota|insufficient_quota"
  :description "OpenAI API key has insufficient quota/credits"
  :remedy ["Add credits to OpenAI account at platform.openai.com"
           "Check billing settings and payment method"
           "Verify API key has proper permissions"]
  :confidence :high
  :frequency :occasional}
